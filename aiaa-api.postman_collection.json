          }
        },
        {
          "name": "Upload template (cert|contract)",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{base_url}}/courses/{{course_id}}/templates/cert",
              "host": ["{{base_url}}"],
              "path": ["courses", "{{course_id}}", "templates", "cert"],
              "variable": []
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [], "description": ".pdf/.doc/.docx, max 15MB. Change 'cert' to 'contract' in the URL for the contract template." }
              ]
            }
          }
        },
        {
          "name": "Download template (cert|contract)",
