            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/courses/{{course_id}}/templates/cert",
              "host": ["{{base_url}}"],
              "path": ["courses", "{{course_id}}", "templates", "cert"]
            }
          }
        }
      ]
