    {
      "name": "Courses (admin · course:edit)",
      "item": [
        {
          "name": "List courses (admin — incl. drafts)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/courses?status=draft",
              "host": ["{{base_url}}"],
              "path": ["courses"],
              "query": [
                { "key": "status", "value": "draft", "description": "draft | open | closed — OMIT (disable) to see ALL statuses. Only staff with course:edit see drafts; the public 'List courses' request never does.", "disabled": false },
                { "key": "level", "value": "", "disabled": true },
                { "key": "category", "value": "", "disabled": true }
              ]
            },
            "description": "Authenticated list (sends Bearer token). A newly created course defaults to status=draft and is hidden from the public 'List courses'. Use this to see drafts, or publish via 'Update course' with {\"status\":\"open\"}."
          }
        },
        {
          "name": "Create course",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var j = pm.response.json();",
                  "if (j.id) pm.collectionVariables.set('course_id', j.id);",
                  "if (j.slug) pm.collectionVariables.set('course_slug', j.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/courses", "host": ["{{base_url}}"], "path": ["courses"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"summer-bootcamp-2026\",\n  \"title_mn\": \"Зуны бүтээлч кэмп\",\n  \"title_en\": \"Summer Bootcamp\",\n  \"tagline_mn\": \"3 долоо хоногийн эрчимжүүлсэн\",\n  \"category\": \"bootcamp\",\n  \"level\": \"junior\",\n  \"status\": \"draft\",\n  \"target_audience\": \"Junior · Нас 10-18\",\n  \"age_min\": 10,\n  \"age_max\": 18,\n  \"start_date\": \"2026-06-01\",\n  \"end_date\": \"2026-06-21\",\n  \"duration_weeks\": 3,\n  \"duration_label\": \"3 долоо хоног\",\n  \"sort_order\": 1,\n  \"format\": \"in_person\",\n  \"price_amount\": 1200000,\n  \"currency\": \"MNT\",\n  \"discount_percent\": 50,\n  \"description_mn\": \"...\",\n  \"has_exam\": false,\n  \"has_final_project\": true,\n  \"final_project_type\": \"showcase\",\n  \"has_attendance\": true,\n  \"attendance_method\": \"qr_scan\",\n  \"google_classroom_url\": \"https://classroom.google.com/...\",\n  \"curriculum\": [\"Week 1\", \"Week 2\", \"Week 3\"],\n  \"whats_included\": [\"Laptop\", \"Certificate\"]\n}"
            }
          }
        },
        {
          "name": "Update course",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/courses/{{course_id}}", "host": ["{{base_url}}"], "path": ["courses", "{{course_id}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"open\",\n  \"discount_percent\": 20\n}" }
          }
        },
        {
          "name": "Delete course",
          "request": {
