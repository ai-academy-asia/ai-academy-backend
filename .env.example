# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# PostgreSQL (matches docker-compose.yml)
POSTGRES_USER=aiaa
POSTGRES_PASSWORD=aiaa_dev_password
POSTGRES_DB=aiaa
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Full SQLAlchemy URL (optional; built from the parts above if omitted)
# DATABASE_URL=postgresql+psycopg2://aiaa:aiaa_dev_password@localhost:5433/aiaa
